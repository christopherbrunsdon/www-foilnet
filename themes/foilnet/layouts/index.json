{{- $pages := where site.RegularPages "Type" "not in" (slice "search") -}}
[
  {{- range $i, $p := $pages -}}
    {{- if $i }},{{ end -}}
    {
      "title":       {{ $p.Title | jsonify }},
      "permalink":   {{ $p.Permalink | jsonify }},
      "description": {{ $p.Description | jsonify }},
      "content":     {{ $p.Plain | jsonify }}
    }
  {{- end -}}
]
